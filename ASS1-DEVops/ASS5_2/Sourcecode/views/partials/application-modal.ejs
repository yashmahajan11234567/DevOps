<div class="modal <%= openModal ? 'is-open' : '' %>" data-modal aria-hidden="<%= openModal ? 'false' : 'true' %>">
  <div class="modal-backdrop" data-close-modal></div>
  <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="application-modal-title">
    <button class="modal-close" type="button" aria-label="Close applicant form" data-close-modal>&times;</button>
    <p class="eyebrow">Applicant Details</p>
    <h2 id="application-modal-title">Submit your application</h2>
    <p class="modal-copy">Enter your details and exam scores. The form saves directly to MongoDB when the database is connected.</p>
    <form method="POST" action="/apply" class="form-grid modal-form">
      <label>
        Full name
        <input type="text" name="name" placeholder="Your name" required />
      </label>
      <label>
        Email
        <input type="email" name="email" placeholder="name@example.com" required />
      </label>
      <label>
        Phone
        <input type="text" name="phone" placeholder="Mobile number" />
      </label>
      <label>
        Program
        <select name="program" required>
          <option value="">Select a program</option>
          <% site.programs.forEach((program) => { %>
            <option><%= program.name %></option>
          <% }) %>
        </select>
      </label>
      <label>
        10th marks
        <input type="number" name="tenthMarks" min="0" max="100" step="0.01" placeholder="e.g. 92" />
      </label>
      <label>
        12th marks
        <input type="number" name="twelfthMarks" min="0" max="100" step="0.01" placeholder="e.g. 88" />
      </label>
      <label>
        CET score
        <input type="number" name="cetScore" min="0" step="0.01" placeholder="CET score" />
      </label>
      <label>
        JEE score
        <input type="number" name="jeeScore" min="0" step="0.01" placeholder="JEE score" />
      </label>
      <label class="full">
        Message
        <textarea name="message" rows="4" placeholder="Share your interests or questions"></textarea>
      </label>
      <div class="full modal-actions">
        <button class="btn primary" type="submit">Submit application</button>
      </div>
    </form>
  </div>
</div>
